generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DependencyType {
  DEPENDENCY
  DEV_DEPENDENCY
}

model Dependency {
  id                 String         @id @default(uuid()) @db.Uuid
  analysisId         String         @map("analysis_id") @db.Uuid
  name               String
  versionRequirement String         @map("version_requirement")
  type               DependencyType
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  analysis Analysis          @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  scores   DependencyScore[]

  @@unique([analysisId, name, type])
  @@index([analysisId])
  @@map("dependencies")
}

model Analysis {
  id           String         @id @default(uuid()) @db.Uuid
  email        String?
  status       AnalysisStatus @default(PENDING)
  resultToken  String         @unique @default(uuid()) @map("result_token") @db.Uuid
  errorMessage String?        @map("error_message")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  dependencies Dependency[]
  result       AnalysisResult?

  @@index([status])
  @@map("analyses")
}

model AnalysisResult {
  id          String   @id @default(uuid()) @db.Uuid
  analysisId  String   @unique @map("analysis_id") @db.Uuid
  globalScore Int      @map("global_score")
  riskLevel   String   @map("risk_level")
  summary     String
  createdAt   DateTime @default(now()) @map("created_at")

  analysis         Analysis          @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  dependencyScores DependencyScore[]

  @@map("analysis_results")
}

model DependencyScore {
  id               String   @id @default(uuid()) @db.Uuid
  analysisResultId String   @map("analysis_result_id") @db.Uuid
  dependencyId     String   @map("dependency_id") @db.Uuid
  score            Int
  riskLevel        String   @map("risk_level")
  popularityScore  Int?     @map("popularity_score")
  maintenanceScore Int?     @map("maintenance_score")
  resolutionQualityScore Int? @map("resolution_quality_score")
  normalizedInputs Json?    @map("normalized_inputs")
  githubMetrics    Json?    @map("github_metrics")
  issueMetrics     Json?    @map("issue_metrics")
  issueData        Json?    @map("issue_data")
  warnings         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  analysisResult AnalysisResult @relation(fields: [analysisResultId], references: [id], onDelete: Cascade)
  dependency     Dependency     @relation(fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([analysisResultId, dependencyId])
  @@index([dependencyId])
  @@map("dependency_scores")
}

model DependencyAnalysisCache {
  id                     String   @id @default(uuid()) @db.Uuid
  cacheKey               String   @unique @map("cache_key")
  ecosystem              String
  packageManager         String   @map("package_manager")
  dependencyName         String   @map("dependency_name")
  versionRequirement     String?  @map("version_requirement")
  versionBucket          String?  @map("version_bucket")
  repositoryOwner        String?  @map("repository_owner")
  repositoryName         String?  @map("repository_name")
  repositoryFullName     String?  @map("repository_full_name")
  repositoryUrl          String?  @map("repository_url")
  githubMinerRaw         Json?    @map("github_miner_raw")
  issuesMiningRaw        Json?    @map("issues_mining_raw")
  issueMetrics           Json?    @map("issue_metrics")
  normalizedMetrics      Json?    @map("normalized_metrics")
  score                  Int?
  riskLevel              String?  @map("risk_level")
  popularityScore        Int?     @map("popularity_score")
  maintenanceScore       Int?     @map("maintenance_score")
  resolutionQualityScore Int?     @map("resolution_quality_score")
  warnings               Json?
  status                 String   @default("SUCCESS")
  issuesConfigHash       String   @map("issues_config_hash")
  cacheVersion           String   @map("cache_version")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  expiresAt              DateTime @map("expires_at")
  lastAccessedAt         DateTime @default(now()) @map("last_accessed_at")

  @@index([dependencyName])
  @@index([repositoryFullName])
  @@index([expiresAt])
  @@map("dependency_analysis_cache")
}

model LeaderboardRepository {
  id                      String   @id @default(uuid()) @db.Uuid
  owner                   String
  name                    String
  fullName                String   @map("full_name")
  url                     String
  description             String?  
  stars                   Int
  forks                   Int
  watchers                Int
  issues                  Int
  pullRequests            Int
  license                 String?
  primaryLanguage         String?
  topics                  String[]
  repositoryCreatedAt     DateTime @map("repository_created_at")
  pushedAt                DateTime @map("pushed_at")
  githubPopularityScore   Int      @map("github_popularity_score")
  githubActivityScore     Int      @map("github_activity_score")
  githubCompatibilityScore Int     @map("github_compatibility_score")
  analysisScore           Int?     @map("analysis_score")
  analysisStatus          String?  @map("analysis_status")
  analysisResultToken     String?  @map("analysis_result_token")
  analysisId              String?  @map("analysis_id")
  packageJsonPresent      Boolean  @map("package_json_present")
  category                String
  rank                    Int
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@unique([fullName, category])
  @@index([category, rank])
  @@index([fullName])
  @@map("leaderboard_repositories")
}
