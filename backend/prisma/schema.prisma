generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DependencyType {
  DEPENDENCY
  DEV_DEPENDENCY
}

model Dependency {
  id                 String         @id @default(uuid()) @db.Uuid
  analysisId         String         @map("analysis_id") @db.Uuid
  name               String
  versionRequirement String         @map("version_requirement")
  type               DependencyType
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  analysis Analysis          @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  scores   DependencyScore[]

  @@unique([analysisId, name, type])
  @@index([analysisId])
  @@map("dependencies")
}

model Analysis {
  id           String         @id @default(uuid()) @db.Uuid
  email        String
  status       AnalysisStatus @default(PENDING)
  resultToken  String         @unique @default(uuid()) @map("result_token") @db.Uuid
  errorMessage String?        @map("error_message")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  dependencies Dependency[]
  result       AnalysisResult?

  @@index([status])
  @@map("analyses")
}

model AnalysisResult {
  id          String   @id @default(uuid()) @db.Uuid
  analysisId  String   @unique @map("analysis_id") @db.Uuid
  globalScore Int      @map("global_score")
  riskLevel   String   @map("risk_level")
  summary     String
  createdAt   DateTime @default(now()) @map("created_at")

  analysis         Analysis          @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  dependencyScores DependencyScore[]

  @@map("analysis_results")
}

model DependencyScore {
  id               String   @id @default(uuid()) @db.Uuid
  analysisResultId String   @map("analysis_result_id") @db.Uuid
  dependencyId     String   @map("dependency_id") @db.Uuid
  score            Int
  riskLevel        String   @map("risk_level")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  analysisResult AnalysisResult @relation(fields: [analysisResultId], references: [id], onDelete: Cascade)
  dependency     Dependency     @relation(fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([analysisResultId, dependencyId])
  @@index([dependencyId])
  @@map("dependency_scores")
}
