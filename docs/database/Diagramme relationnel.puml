@startuml
title StackIQ - Domain Model

skinparam classAttributeIconSize 0
skinparam shadowing false

class Analysis {
  +id: String
  +email: String
  +status: AnalysisStatus
  +resultToken: String
  +errorMessage: String?
  +createdAt: DateTime
  +updatedAt: DateTime
}

class Dependency {
  +id: String
  +analysisId: String
  +name: String
  +versionRequirement: String
  +type: DependencyType
  +createdAt: DateTime
  +updatedAt: DateTime
}

class AnalysisResult {
  +id: String
  +analysisId: String
  +globalScore: Int
  +riskLevel: String
  +summary: String
  +createdAt: DateTime
}

class DependencyScore {
  +id: String
  +analysisResultId: String
  +dependencyId: String
  +score: Int
  +riskLevel: String
  +createdAt: DateTime
  +updatedAt: DateTime
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DependencyType {
  DEPENDENCY
  DEV_DEPENDENCY
}

Analysis "1" --> "many" Dependency : contient
Analysis "1" --> "0..1" AnalysisResult : produit
AnalysisResult "1" --> "many" DependencyScore : contient
Dependency "1" --> "many" DependencyScore : reçoit

Analysis --> AnalysisStatus
Dependency --> DependencyType

@enduml